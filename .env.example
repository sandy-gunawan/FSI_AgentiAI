# ============================================================
# Bank Nusantara Sejahtera (BNS) — Agentic AI Financing Demo
# Copy to `.env` and fill in. Agent Framework does NOT auto-load
# .env; the app calls load_dotenv() at startup.
# ============================================================

# ---- Microsoft Foundry (LLM backend) ----
FOUNDRY_PROJECT_ENDPOINT=https://<your-foundry>.services.ai.azure.com/api/projects/<your-project>
FOUNDRY_MODEL=gpt-4o-mini

# ---- Observability ----
# true = send OpenTelemetry traces/metrics/logs
ENABLE_INSTRUMENTATION=true
# Local Aspire dashboard (docker). Leave unset in Azure (use App Insights).
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=bns-financing-agents
# Azure Application Insights (used when deployed to Azure)
APPLICATIONINSIGHTS_CONNECTION_STRING=

# ---- Azure AI Content Safety (governance) ----
# Optional locally; if unset the app falls back to a keyword/regex redactor.
CONTENT_SAFETY_ENDPOINT=
CONTENT_SAFETY_KEY=

# ---- Mock surrounding systems (one combined REST service) ----
REST_BASE_URL=http://localhost:8080

# MCP servers are launched over stdio by default (see app/tools/*_mcp.py).

# ---- Governance ----
# Max LLM token budget per financing request (blocks when exceeded).
TOKEN_BUDGET_PER_REQUEST=60000
# Retail loans at/above this IDR amount are routed to human review (UC2).
AUTO_APPROVE_CEILING_IDR=100000000

# ---- App state ----
AUDIT_DB_PATH=data/audit.db
CHECKPOINT_DIR=.checkpoints
