# ============================================================================
# bcafinance — Invoice Financing Document Review (copy to .env and fill in)
# ============================================================================

# ---- Microsoft Foundry (hosts the 3 prompt agents; REUSE existing project) --
FOUNDRY_PROJECT_ENDPOINT=https://bnsfoundryer3wj7.services.ai.azure.com/api/projects/financing
FOUNDRY_MODEL=gpt-4o-mini

# ---- Option A: Azure AI Document Intelligence -------------------------------
DOC_INTELLIGENCE_ENDPOINT=https://<your-di-resource>.cognitiveservices.azure.com/
# Leave DOC_INTELLIGENCE_KEY empty to use Managed Identity / DefaultAzureCredential.
DOC_INTELLIGENCE_KEY=

# ---- Option 1 (DI agentic): the tools service the extractor agent calls ------
# Public URL of ca-bcafinance-tools. Leave empty to disable the "DI agentic" mode.
TOOLS_SERVICE_URL=

# ---- Blob Storage (invoice images + hot-reloadable review_rules.yaml) -------
# Leave BLOB_ACCOUNT_URL empty to run fully local (uses config/review_rules.yaml).
BLOB_ACCOUNT_URL=
BLOB_CONTAINER_CONFIG=bca-config
BLOB_CONTAINER_INVOICES=bca-invoices
# Blob name of the review-rules file inside BLOB_CONTAINER_CONFIG:
REVIEW_RULES_BLOB=review_rules.yaml

# ---- Observability ----------------------------------------------------------
ENABLE_INSTRUMENTATION=false
APPLICATIONINSIGHTS_CONNECTION_STRING=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=bcafinance-invoice-review

# ---- Governance -------------------------------------------------------------
TOKEN_BUDGET_PER_REQUEST=60000
AUDIT_DB_PATH=data/audit.db
